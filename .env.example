# ═════════════════════════════════════════════════════════════════════════════
# ByteBeat — variables de entorno
#
# ELIGE UN MODO:
#   • MODO A (Colab / sin GPU)  → descomenta el bloque "CLOUD"
#   • MODO B (GPU local Docker) → descomenta el bloque "LOCAL"  (default)
# ═════════════════════════════════════════════════════════════════════════════


# ── MODO B: LOCAL (Docker Redis + Postgres locales + GPU local) ─────────────
# Levantar con:  docker compose --profile local up -d
POSTGRES_PASSWORD=changeme_local
DATABASE_URL=postgresql://mtuser:changeme_local@db:5432/music_transformer
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0


# ── MODO A: CLOUD (Colab corre el generation_worker — sin GPU local) ────────
# Comenta el bloque "MODO B" de arriba y descomenta lo siguiente.
# Crea cuentas gratuitas en:
#   • Upstash (Redis):   https://console.upstash.com  → Create Database → Region más cercana
#   • Neon (Postgres):   https://console.neon.tech    → New Project
# Levantar con:  docker compose up -d   (sin --profile)
#
# DATABASE_URL=postgresql://USER:PASS@HOST.neon.tech/DBNAME?sslmode=require
# CELERY_BROKER_URL=rediss://default:TOKEN@HOST.upstash.io:6379?ssl_cert_reqs=CERT_NONE
# CELERY_RESULT_BACKEND=rediss://default:TOKEN@HOST.upstash.io:6379?ssl_cert_reqs=CERT_NONE


# ── Storage Supabase (SIEMPRE — sirve para ambos modos) ─────────────────────
# Crear bucket "bytebeat" público en: https://app.supabase.com → Storage
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_KEY=TU_SERVICE_ROLE_KEY
SUPABASE_BUCKET=bytebeat


# ── Auth JWT ────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET_KEY=REEMPLAZA_CON_UNA_CLAVE_SEGURA
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080


# ── Google OAuth (opcional) ─────────────────────────────────────────────────
# Crear credenciales en: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback


# ── Frontend / CORS ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8000
