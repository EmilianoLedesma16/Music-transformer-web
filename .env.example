# ── Local Docker Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_local
DATABASE_URL=postgresql://mtuser:changeme_local@db:5432/music_transformer

# ── Celery / Redis ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── Auth JWT ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_A_REAL_SECRET_32_BYTES
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Crear en: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs: http://localhost:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Supabase Storage ───────────────────────────────────────────────────────────
# Crear en: https://app.supabase.com -> Storage -> New bucket "bytebeat" (public)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=bytebeat

# ── CORS / Frontend ────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8000
